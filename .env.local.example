# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key: server-side only, never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic API key for the real AI Assistant (console.anthropic.com)
ANTHROPIC_API_KEY=

# Stripe Connect for real payment links (dashboard.stripe.com)
STRIPE_SECRET_KEY=
# From the Connect webhook endpoint you create in the Stripe dashboard
STRIPE_WEBHOOK_SECRET=

# Comma-separated emails allowed into /admin (the Super Admin console).
# Anyone signed in but not on this list is redirected away.
PLATFORM_ADMIN_EMAILS=
